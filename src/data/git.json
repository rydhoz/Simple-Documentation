{
  "setup-config": [
    { "name": "git config --global user.name", "desc": "Set nama pengguna global.", "example": "git config --global user.name \"Ridho Akbar\"", "output": "Nama tersimpan" },
    { "name": "git config --global user.email", "desc": "Set email pengguna global.", "example": "git config --global user.email \"ridho@email.com\"", "output": "Email tersimpan" },
    { "name": "git config --list", "desc": "Lihat semua konfigurasi Git.", "example": "git config --list", "output": "user.name=Ridho..." },
    { "name": "git config --global init.defaultBranch", "desc": "Set default branch name (main).", "example": "git config --global init.defaultBranch main", "output": "Default: main" },
    { "name": "git config --global core.editor", "desc": "Set editor default untuk commit message.", "example": "git config --global core.editor \"code --wait\"", "output": "VS Code" },
    { "name": "git config --global core.autocrlf", "desc": "Atur line ending (true=Windows, input=Mac/Linux).", "example": "git config --global core.autocrlf true", "output": "CRLF auto" },
    { "name": "git config --global alias.<shortcut>", "desc": "Buat shortcut perintah.", "example": "git config --global alias.co checkout", "output": "git co = git checkout" },
    { "name": "git config --global --edit", "desc": "Edit global config file langsung.", "example": "git config --global --edit", "output": "Buka .gitconfig" }
  ],
  "init-clone": [
    { "name": "git init", "desc": "Inisialisasi repo Git baru di folder.", "example": "git init", "output": "Initialized empty Git repository" },
    { "name": "git init -b <branch>", "desc": "Inisialisasi dengan branch tertentu.", "example": "git init -b main", "output": "Branch: main" },
    { "name": "git clone <url>", "desc": "Clone repo dari remote.", "example": "git clone https://github.com/user/repo.git", "output": "Folder repo terdownload" },
    { "name": "git clone <url> <folder>", "desc": "Clone ke folder spesifik.", "example": "git clone https://github.com/user/repo.git my-project", "output": "Folder: my-project" },
    { "name": "git clone --branch <branch> <url>", "desc": "Clone branch tertentu saja.", "example": "git clone --branch dev https://github.com/user/repo.git", "output": "Branch dev" },
    { "name": "git clone --depth 1 <url>", "desc": "Shallow clone — hanya commit terbaru (lebih cepat).", "example": "git clone --depth 1 https://github.com/user/repo.git", "output": "Ukuran kecil" },
    { "name": "git clone --single-branch <url>", "desc": "Clone hanya 1 branch.", "example": "git clone --single-branch --branch main <url>", "output": "1 branch saja" }
  ],
  "basic-snapshot": [
    { "name": "git status", "desc": "Cek status working directory & staging area.", "example": "git status", "output": "modified: file.txt" },
    { "name": "git status -s", "desc": "Status singkat (short).", "example": "git status -s", "output": " M file.txt" },
    { "name": "git add <file>", "desc": "Tambahkan file ke staging area.", "example": "git add index.html", "output": "Staged" },
    { "name": "git add .", "desc": "Tambahkan semua perubahan ke staging.", "example": "git add .", "output": "Semua staged" },
    { "name": "git add -A", "desc": "Tambahkan semua termasuk delete.", "example": "git add -A", "output": "Semua (add, modify, delete)" },
    { "name": "git add -p", "desc": "Tambahkan perubahan secara interaktif (patch).", "example": "git add -p", "output": "Pilih hunk per hunk" },
    { "name": "git commit -m \"msg\"", "desc": "Commit perubahan dengan pesan.", "example": "git commit -m \"feat: add login page\"", "output": "[main a1b2c3d] feat: add login page" },
    { "name": "git commit -am \"msg\"", "desc": "Add + commit sekaligus (hanya file tracked).", "example": "git commit -am \"fix: typo\"", "output": "Staged & committed" },
    { "name": "git commit --amend", "desc": "Ubah commit terakhir (pesan atau isi).", "example": "git commit --amend -m \"new message\"", "output": "Commit terakhir diubah" },
    { "name": "git commit --amend --no-edit", "desc": "Tambahkan perubahan ke commit terakhir tanpa ubah pesan.", "example": "git add . && git commit --amend --no-edit", "output": "Commit terakhir ditambah" },
    { "name": "git commit --allow-empty", "desc": "Commit kosong (untuk trigger CI/CD).", "example": "git commit --allow-empty -m \"trigger build\"", "output": "Commit kosong" },
    { "name": "git reset <file>", "desc": "Unstage file (keluarkan dari staging).", "example": "git reset index.html", "output": "Unstaged" },
    { "name": "git reset HEAD <file>", "desc": "Unstage file (sintaks lama).", "example": "git reset HEAD file.txt", "output": "Unstaged" },
    { "name": "git restore --staged <file>", "desc": "Unstage file (cara modern).", "example": "git restore --staged file.txt", "output": "Unstaged" },
    { "name": "git restore <file>", "desc": "Kembalikan file ke versi terakhir commit (buang perubahan).", "example": "git restore file.txt", "output": "Perubahan hilang" },
    { "name": "git clean -n", "desc": "Lihat file untracked yang akan dihapus (dry run).", "example": "git clean -n", "output": "Would remove file.txt" },
    { "name": "git clean -f", "desc": "Hapus file untracked.", "example": "git clean -f", "output": "Removing file.txt" },
    { "name": "git clean -fd", "desc": "Hapus file & folder untracked.", "example": "git clean -fd", "output": "Removing folder/" }
  ],
  "diff-log": [
    { "name": "git diff", "desc": "Lihat perubahan yang belum di-staging.", "example": "git diff", "output": "+ baris baru" },
    { "name": "git diff --staged", "desc": "Lihat perubahan yang sudah di-staging.", "example": "git diff --staged", "output": "+ baris staged" },
    { "name": "git diff <commit1> <commit2>", "desc": "Bandingkan dua commit.", "example": "git diff abc123 def456", "output": "Perbedaan" },
    { "name": "git diff <branch1>..<branch2>", "desc": "Bandingkan dua branch.", "example": "git diff main..dev", "output": "Perbedaan branch" },
    { "name": "git diff --name-only", "desc": "Hanya tampilkan nama file yang berubah.", "example": "git diff --name-only", "output": "file1.txt\nfile2.js" },
    { "name": "git log", "desc": "Lihat riwayat commit.", "example": "git log", "output": "commit abc... Author: ..." },
    { "name": "git log --oneline", "desc": "Log ringkas 1 baris per commit.", "example": "git log --oneline", "output": "a1b2c3d feat: login" },
    { "name": "git log --oneline --graph", "desc": "Log dengan grafik branch.", "example": "git log --oneline --graph --all", "output": "* a1b2c3d (HEAD -> main)" },
    { "name": "git log -p", "desc": "Log dengan patch/diff setiap commit.", "example": "git log -p", "output": "+ baris ditambahkan" },
    { "name": "git log --stat", "desc": "Log dengan statistik file berubah.", "example": "git log --stat", "output": "2 files changed, 10 insertions" },
    { "name": "git log --author=\"name\"", "desc": "Filter log by author.", "example": "git log --author=\"Ridho\"", "output": "Commit Ridho saja" },
    { "name": "git log --since=\"date\"", "desc": "Log sejak tanggal tertentu.", "example": "git log --since=\"2025-01-01\"", "output": "Sejak 2025" },
    { "name": "git log -<n>", "desc": "Tampilkan n commit terakhir.", "example": "git log -5", "output": "5 commit terakhir" },
    { "name": "git show <commit>", "desc": "Lihat detail 1 commit.", "example": "git show a1b2c3d", "output": "diff + metadata" },
    { "name": "git blame <file>", "desc": "Lihat siapa yang mengubah setiap baris.", "example": "git blame index.html", "output": "a1b2c3d (Ridho 2025-01-01) line" },
    { "name": "git shortlog", "desc": "Ringkasan commit per author.", "example": "git shortlog", "output": "Ridho (5): feat: ..." }
  ],
  "branch": [
    { "name": "git branch", "desc": "Lihat daftar branch lokal.", "example": "git branch", "output": "* main\n  dev" },
    { "name": "git branch -r", "desc": "Lihat branch remote.", "example": "git branch -r", "output": "origin/main" },
    { "name": "git branch -a", "desc": "Lihat semua branch (lokal + remote).", "example": "git branch -a", "output": "Semua branch" },
    { "name": "git branch <nama>", "desc": "Buat branch baru.", "example": "git branch feature-login", "output": "Branch dibuat" },
    { "name": "git checkout <branch>", "desc": "Pindah ke branch (cara lama).", "example": "git checkout dev", "output": "Switched to branch 'dev'" },
    { "name": "git switch <branch>", "desc": "Pindah ke branch (cara modern).", "example": "git switch main", "output": "Switched to 'main'" },
    { "name": "git switch -c <branch>", "desc": "Buat + pindah ke branch baru.", "example": "git switch -c feature- baru", "output": "Switched to new branch" },
    { "name": "git checkout -b <branch>", "desc": "Buat + pindah (cara lama).", "example": "git checkout -b feature-baru", "output": "Switched to new branch" },
    { "name": "git branch -d <branch>", "desc": "Hapus branch lokal (aman — sudah di-merge).", "example": "git branch -d feature-lama", "output": "Deleted branch" },
    { "name": "git branch -D <branch>", "desc": "Hapus branch lokal (paksa — belum merge).", "example": "git branch -D feature-lama", "output": "Deleted branch" },
    { "name": "git branch -m <old> <new>", "desc": "Rename branch.", "example": "git branch -m old-name new-name", "output": "Renamed" },
    { "name": "git branch -m <new>", "desc": "Rename branch saat ini.", "example": "git branch -m new-name", "output": "Renamed current" }
  ],
  "merge-rebase": [
    { "name": "git merge <branch>", "desc": "Merge branch ke branch saat ini.", "example": "git merge feature-login", "output": "Merge made by 'ort' strategy" },
    { "name": "git merge --no-ff <branch>", "desc": "Merge tanpa fast-forward (selalu buat merge commit).", "example": "git merge --no-ff feature", "output": "Merge commit dibuat" },
    { "name": "git merge --squash <branch>", "desc": "Squash semua commit branch jadi 1 sebelum merge.", "example": "git merge --squash feature", "output": "Siap di-commit manual" },
    { "name": "git merge --abort", "desc": "Batalkan merge yang sedang conflict.", "example": "git merge --abort", "output": "Kembali sebelum merge" },
    { "name": "git rebase <branch>", "desc": "Re-apply commit di atas branch lain (history linear).", "example": "git rebase main", "output": "Successfully rebased" },
    { "name": "git rebase -i <commit>", "desc": "Interactive rebase — squash, reword, drop commit.", "example": "git rebase -i HEAD~3", "output": "Editor terbuka" },
    { "name": "git rebase --continue", "desc": "Lanjutkan rebase setelah resolve conflict.", "example": "git rebase --continue", "output": "Rebase lanjut" },
    { "name": "git rebase --abort", "desc": "Batalkan rebase.", "example": "git rebase --abort", "output": "Kembali sebelum rebase" },
    { "name": "git rebase --skip", "desc": "Lewati commit yang conflict.", "example": "git rebase --skip", "output": "Commit dilewati" },
    { "name": "git cherry-pick <commit>", "desc": "Ambil 1 commit dari branch lain ke branch saat ini.", "example": "git cherry-pick a1b2c3d", "output": "Commit dipindahkan" },
    { "name": "git cherry-pick --continue", "desc": "Lanjutkan cherry-pick setelah resolve.", "example": "git cherry-pick --continue", "output": "Cherry-pick lanjut" },
    { "name": "git cherry-pick --abort", "desc": "Batalkan cherry-pick.", "example": "git cherry-pick --abort", "output": "Kembali" }
  ],
  "stash": [
    { "name": "git stash", "desc": "Simpan perubahan sementara (working + staging).", "example": "git stash", "output": "Saved working directory" },
    { "name": "git stash -m \"msg\"", "desc": "Stash dengan pesan.", "example": "git stash -m \"WIP: login\"", "output": "Saved with message" },
    { "name": "git stash -u", "desc": "Stash termasuk file untracked.", "example": "git stash -u", "output": "Termasuk untracked" },
    { "name": "git stash -a", "desc": "Stash termasuk file ignored.", "example": "git stash -a", "output": "Semua" },
    { "name": "git stash list", "desc": "Lihat daftar stash.", "example": "git stash list", "output": "stash@{0}: WIP on main: ..." },
    { "name": "git stash pop", "desc": "Ambil stash terakhir & hapus dari list.", "example": "git stash pop", "output": "Perubahan kembali" },
    { "name": "git stash pop stash@{n}", "desc": "Ambil stash ke-n.", "example": "git stash pop stash@{1}", "output": "Stash ke-1 kembali" },
    { "name": "git stash apply", "desc": "Ambil stash terakhir TANPA hapus dari list.", "example": "git stash apply", "output": "Perubahan kembali, stash tetap ada" },
    { "name": "git stash drop stash@{n}", "desc": "Hapus stash ke-n.", "example": "git stash drop stash@{0}", "output": "Dropped" },
    { "name": "git stash clear", "desc": "Hapus semua stash.", "example": "git stash clear", "output": "Semua stash hilang" }
  ],
  "remote": [
    { "name": "git remote", "desc": "Lihat daftar remote.", "example": "git remote", "output": "origin" },
    { "name": "git remote -v", "desc": "Lihat URL remote.", "example": "git remote -v", "output": "origin https://github.com/..." },
    { "name": "git remote add <name> <url>", "desc": "Tambah remote baru.", "example": "git remote add origin https://github.com/user/repo.git", "output": "Remote origin ditambahkan" },
    { "name": "git remote remove <name>", "desc": "Hapus remote.", "example": "git remote remove origin", "output": "Remote dihapus" },
    { "name": "git remote rename <old> <new>", "desc": "Ganti nama remote.", "example": "git remote rename origin upstream", "output": "Renamed" },
    { "name": "git remote show <name>", "desc": "Info detail remote.", "example": "git remote show origin", "output": "URL, HEAD branch, tracking..." },
    { "name": "git remote set-url <name> <url>", "desc": "Ganti URL remote.", "example": "git remote set-url origin git@github.com:user/repo.git", "output": "URL diganti ke SSH" }
  ],
  "push-pull-fetch": [
    { "name": "git push", "desc": "Push commit ke remote (branch saat ini).", "example": "git push", "output": "Pushed to origin/main" },
    { "name": "git push -u origin <branch>", "desc": "Push branch baru & set upstream.", "example": "git push -u origin feature-login", "output": "Branch 'feature-login' set up to track" },
    { "name": "git push --all", "desc": "Push semua branch ke remote.", "example": "git push --all origin", "output": "Semua branch terpush" },
    { "name": "git push --tags", "desc": "Push semua tag ke remote.", "example": "git push --tags", "output": "Tags terpush" },
    { "name": "git push --force", "desc": "Force push (timpa history remote — HATI-HATI).", "example": "git push --force", "output": "⚠️ Remote history ditimpa" },
    { "name": "git push --force-with-lease", "desc": "Force push lebih aman (cek dulu gak ada commit baru).", "example": "git push --force-with-lease", "output": "Aman force push" },
    { "name": "git push origin --delete <branch>", "desc": "Hapus branch di remote.", "example": "git push origin --delete feature-lama", "output": "Deleted remote branch" },
    { "name": "git fetch", "desc": "Ambil data remote tanpa merge.", "example": "git fetch", "output": "Data terdownload" },
    { "name": "git fetch --prune", "desc": "Fetch + hapus tracking branch yang sudah dihapus di remote.", "example": "git fetch --prune", "output": "Branch remote usang dihapus" },
    { "name": "git pull", "desc": "Fetch + merge ke branch saat ini.", "example": "git pull", "output": "Updated" },
    { "name": "git pull --rebase", "desc": "Fetch + rebase (history linear).", "example": "git pull --rebase", "output": "Rebased" },
    { "name": "git pull --ff-only", "desc": "Pull hanya jika bisa fast-forward (aman).", "example": "git pull --ff-only", "output": "Fast-forward" }
  ],
  "tag": [
    { "name": "git tag", "desc": "Lihat daftar tag.", "example": "git tag", "output": "v1.0.0\nv1.1.0" },
    { "name": "git tag <name>", "desc": "Buat lightweight tag.", "example": "git tag v1.0.0", "output": "Tag v1.0.0" },
    { "name": "git tag -a <name> -m \"msg\"", "desc": "Buat annotated tag (disarankan).", "example": "git tag -a v2.0.0 -m \"Release v2\"", "output": "Annotated tag v2.0.0" },
    { "name": "git tag -d <name>", "desc": "Hapus tag lokal.", "example": "git tag -d v1.0.0", "output": "Deleted tag" },
    { "name": "git push origin <tag>", "desc": "Push 1 tag ke remote.", "example": "git push origin v1.0.0", "output": "Tag terpush" },
    { "name": "git push origin --delete <tag>", "desc": "Hapus tag di remote.", "example": "git push origin --delete v1.0.0", "output": "Remote tag deleted" },
    { "name": "git checkout <tag>", "desc": "Checkout ke tag (detached HEAD).", "example": "git checkout v1.0.0", "output": "HEAD detached at v1.0.0" }
  ],
  "undo": [
    { "name": "git reset --soft <commit>", "desc": "Reset HEAD ke commit, simpan perubahan di staging.", "example": "git reset --soft HEAD~1", "output": "Commit terakhir di-undo, file tetap staged" },
    { "name": "git reset --mixed <commit>", "desc": "Reset HEAD ke commit, simpan perubahan di working (default).", "example": "git reset HEAD~1", "output": "Commit di-undo, file unstaged" },
    { "name": "git reset --hard <commit>", "desc": "Reset HEAD & buang semua perubahan (BAHAYA).", "example": "git reset --hard HEAD~1", "output": "⚠️ Perubahan hilang permanen" },
    { "name": "git revert <commit>", "desc": "Buat commit baru yang membatalkan commit tertentu (AMAN).", "example": "git revert a1b2c3d", "output": "Commit revert dibuat" },
    { "name": "git revert --no-commit <commit>", "desc": "Revert tanpa auto-commit.", "example": "git revert --no-commit a1b2c3d", "output": "Perubahan di staging" },
    { "name": "git reflog", "desc": "Lihat history HEAD (penyelamat commit hilang).", "example": "git reflog", "output": "a1b2c3d HEAD@{0}: commit: ..." },
    { "name": "git checkout <commit> -- <file>", "desc": "Kembalikan 1 file ke versi commit tertentu.", "example": "git checkout a1b2c3d -- index.html", "output": "File kembali" }
  ],
  "ignore": [
    { "name": ".gitignore", "desc": "File untuk mengabaikan file/folder dari Git.", "example": "node_modules/\n.env\n.DS_Store", "output": "File diabaikan" },
    { "name": "git rm --cached <file>", "desc": "Hentikan tracking file (tetap ada di lokal).", "example": "git rm --cached file.log", "output": "Untracked" },
    { "name": "git rm <file>", "desc": "Hapus file dari Git & lokal.", "example": "git rm file.log", "output": "Deleted" },
    { "name": "git rm -r <folder>", "desc": "Hapus folder dari Git & lokal.", "example": "git rm -r old-folder", "output": "Folder deleted" },
    { "name": "git check-ignore <file>", "desc": "Cek apakah file diabaikan .gitignore.", "example": "git check-ignore node_modules/", "output": "node_modules/" }
  ],
  "github-cli": [
    { "name": "gh auth login", "desc": "Login ke GitHub CLI.", "example": "gh auth login", "output": "Authenticated" },
    { "name": "gh repo create <name>", "desc": "Buat repo baru di GitHub.", "example": "gh repo create my-project --public", "output": "Repo created" },
    { "name": "gh repo clone <user/repo>", "desc": "Clone repo via GitHub CLI.", "example": "gh repo clone user/repo", "output": "Cloned" },
    { "name": "gh repo view", "desc": "Buka repo di browser.", "example": "gh repo view --web", "output": "Browser terbuka" },
    { "name": "gh pr create", "desc": "Buat Pull Request.", "example": "gh pr create --title \"feat: login\" --body \"...\"", "output": "PR created" },
    { "name": "gh pr list", "desc": "Lihat daftar PR.", "example": "gh pr list", "output": "#1 feat: login" },
    { "name": "gh pr checkout <n>", "desc": "Checkout branch dari PR.", "example": "gh pr checkout 1", "output": "Switched" },
    { "name": "gh pr merge <n>", "desc": "Merge PR.", "example": "gh pr merge 1 --squash", "output": "Merged" },
    { "name": "gh issue create", "desc": "Buat issue baru.", "example": "gh issue create --title \"bug: ...\" --body \"...\"", "output": "Issue #1 created" },
    { "name": "gh issue list", "desc": "Lihat daftar issue.", "example": "gh issue list", "output": "#1 bug: ..." },
    { "name": "gh release create <tag>", "desc": "Buat release.", "example": "gh release create v1.0.0 --title \"v1.0.0\"", "output": "Release created" },
    { "name": "gh gist create <file>", "desc": "Buat gist dari file.", "example": "gh gist create script.js --public", "output": "Gist created" }
  ],
  "conventional-commits": [
    { "name": "feat:", "desc": "Fitur baru.", "example": "feat: add login page", "output": "Minor version bump" },
    { "name": "fix:", "desc": "Perbaikan bug.", "example": "fix: resolve navbar overlap", "output": "Patch version bump" },
    { "name": "chore:", "desc": "Tugas rutin / maintenance.", "example": "chore: update dependencies", "output": "No version bump" },
    { "name": "docs:", "desc": "Perubahan dokumentasi.", "example": "docs: update README", "output": "No version bump" },
    { "name": "style:", "desc": "Formatting, spasi, dll (tanpa ubah logika).", "example": "style: fix indentation", "output": "No version bump" },
    { "name": "refactor:", "desc": "Refactor kode tanpa ubah fitur.", "example": "refactor: simplify auth logic", "output": "No version bump" },
    { "name": "perf:", "desc": "Performa optimization.", "example": "perf: lazy load images", "output": "Patch version bump" },
    { "name": "test:", "desc": "Tambah/perbaiki testing.", "example": "test: add unit test for login", "output": "No version bump" },
    { "name": "build:", "desc": "Perubahan build system/dependencies.", "example": "build: upgrade webpack to v5", "output": "No version bump" },
    { "name": "ci:", "desc": "Perubahan CI/CD.", "example": "ci: add GitHub Actions workflow", "output": "No version bump" },
    { "name": "revert:", "desc": "Membatalkan commit sebelumnya.", "example": "revert: feat: add login page", "output": "Patch version bump" },
    { "name": "BREAKING CHANGE:", "desc": "Perubahan yang tidak backward-compatible.", "example": "feat!: drop support for Node 14\n\nBREAKING CHANGE: ...", "output": "Major version bump" }
  ]
}