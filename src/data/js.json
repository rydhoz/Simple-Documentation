{
  "string": [
    {
      "name": ".length",
      "desc": "Mengembalikan panjang string.",
      "example": "\"hello\".length",
      "output": "5"
    },
    {
      "name": ".charAt(index)",
      "desc": "Mengembalikan karakter pada posisi index.",
      "example": "\"hello\".charAt(1)",
      "output": "\"e\""
    },
    {
      "name": ".at(index)",
      "desc": "Mengembalikan karakter pada index. Bisa negatif.",
      "example": "\"hello\".at(-1)",
      "output": "\"o\""
    },
    {
      "name": ".concat(str)",
      "desc": "Menggabungkan string.",
      "example": "\"Hello\".concat(\" World\")",
      "output": "\"Hello World\""
    },
    {
      "name": ".includes(str)",
      "desc": "Mengecek apakah string mengandung substring.",
      "example": "\"hello\".includes(\"ll\")",
      "output": "true"
    },
    {
      "name": ".indexOf(str)",
      "desc": "Index pertama substring. -1 jika tidak ditemukan.",
      "example": "\"hello\".indexOf(\"l\")",
      "output": "2"
    },
    {
      "name": ".lastIndexOf(str)",
      "desc": "Index terakhir substring. -1 jika tidak ditemukan.",
      "example": "\"hello\".lastIndexOf(\"l\")",
      "output": "3"
    },
    {
      "name": ".slice(start, end)",
      "desc": "Potong string. Support negatif.",
      "example": "\"hello\".slice(1, 3)",
      "output": "\"el\""
    },
    {
      "name": ".substring(start, end)",
      "desc": "Potong string dari start sampai end.",
      "example": "\"hello\".substring(1, 3)",
      "output": "\"el\""
    },
    {
      "name": ".substr(start, length)",
      "desc": "Potong string mulai dari start sebanyak length karakter. (Deprecated)",
      "example": "\"hello\".substr(1, 3)",
      "output": "\"ell\""
    },
    {
      "name": ".toUpperCase()",
      "desc": "Ubah ke huruf besar.",
      "example": "\"hello\".toUpperCase()",
      "output": "\"HELLO\""
    },
    {
      "name": ".toLowerCase()",
      "desc": "Ubah ke huruf kecil.",
      "example": "\"HELLO\".toLowerCase()",
      "output": "\"hello\""
    },
    {
      "name": ".trim()",
      "desc": "Hapus spasi awal dan akhir.",
      "example": "\"  hi  \".trim()",
      "output": "\"hi\""
    },
    {
      "name": ".trimStart()",
      "desc": "Hapus spasi di awal.",
      "example": "\"  hi  \".trimStart()",
      "output": "\"hi  \""
    },
    {
      "name": ".trimEnd()",
      "desc": "Hapus spasi di akhir.",
      "example": "\"  hi  \".trimEnd()",
      "output": "\"  hi\""
    },
    {
      "name": ".split(separator)",
      "desc": "Pecah string jadi array.",
      "example": "\"a,b,c\".split(\",\")",
      "output": "[\"a\",\"b\",\"c\"]"
    },
    {
      "name": ".replace(old, new)",
      "desc": "Ganti substring pertama ditemukan.",
      "example": "\"haha\".replace(\"ha\", \"he\")",
      "output": "\"heha\""
    },
    {
      "name": ".replaceAll(old, new)",
      "desc": "Ganti semua substring.",
      "example": "\"haha\".replaceAll(\"ha\", \"he\")",
      "output": "\"hehe\""
    },
    {
      "name": ".startsWith(str)",
      "desc": "Mengecek apakah string diawali substring tertentu.",
      "example": "\"hello\".startsWith(\"he\")",
      "output": "true"
    },
    {
      "name": ".endsWith(str)",
      "desc": "Mengecek apakah string diakhiri substring tertentu.",
      "example": "\"hello\".endsWith(\"lo\")",
      "output": "true"
    },
    {
      "name": ".padStart(targetLength, padString)",
      "desc": "Menambah karakter di awal sampai panjang tertentu.",
      "example": "\"5\".padStart(3, \"0\")",
      "output": "\"005\""
    },
    {
      "name": ".padEnd(targetLength, padString)",
      "desc": "Menambah karakter di akhir sampai panjang tertentu.",
      "example": "\"5\".padEnd(3, \"0\")",
      "output": "\"500\""
    },
    {
      "name": ".repeat(count)",
      "desc": "Mengulang string beberapa kali.",
      "example": "\"ha\".repeat(3)",
      "output": "\"hahaha\""
    },
    {
      "name": ".match(regex)",
      "desc": "Mencari kecocokan string dengan regex.",
      "example": "\"hello\".match(/l/g)",
      "output": "[\"l\",\"l\"]"
    },
    {
      "name": ".matchAll(regex)",
      "desc": "Mencari semua kecocokan regex (iterator).",
      "example": "for (const m of \"hello\".matchAll(/l/g)) console.log(m)",
      "output": "iterator"
    },
    {
      "name": ".search(regex)",
      "desc": "Mencari index pertama yang cocok dengan regex.",
      "example": "\"hello\".search(/ll/)",
      "output": "2"
    }
  ],
  "array": {
    "static": [
      {
        "name": "Array.from(iterable)",
        "desc": "Membuat array dari iterable atau array-like.",
        "example": "Array.from('hello')",
        "output": "['h','e','l','l','o']"
      },
      {
        "name": "Array.isArray(val)",
        "desc": "Mengecek apakah nilai adalah array.",
        "example": "Array.isArray([1,2])",
        "output": "true"
      },
      {
        "name": "Array.of(...items)",
        "desc": "Membuat array dari argumen.",
        "example": "Array.of(1,2,3)",
        "output": "[1,2,3]"
      }
    ],
    "instance": [
      {
        "name": ".length",
        "desc": "Jumlah elemen array.",
        "example": "[1,2,3].length",
        "output": "3",
        "mutates": false
      },
      {
        "name": ".push(item)",
        "desc": "Tambah elemen ke akhir. (Mutasi)",
        "example": "const arr = [1]; arr.push(2); arr",
        "output": "[1, 2]",
        "mutates": true
      },
      {
        "name": ".pop()",
        "desc": "Hapus elemen terakhir. (Mutasi)",
        "example": "const arr = [1,2]; arr.pop(); arr",
        "output": "[1]",
        "mutates": true
      },
      {
        "name": ".shift()",
        "desc": "Hapus elemen pertama. (Mutasi)",
        "example": "const arr = [1,2]; arr.shift(); arr",
        "output": "[2]",
        "mutates": true
      },
      {
        "name": ".unshift(item)",
        "desc": "Tambah elemen ke awal. (Mutasi)",
        "example": "const arr = [2]; arr.unshift(1); arr",
        "output": "[1, 2]",
        "mutates": true
      },
      {
        "name": ".splice(start, deleteCount, ...items)",
        "desc": "Menghapus/menambah elemen di tengah. (Mutasi)",
        "example": "const arr = [1,2,3]; arr.splice(1,1); arr",
        "output": "[1,3]",
        "mutates": true
      },
      {
        "name": ".reverse()",
        "desc": "Membalik urutan array. (Mutasi)",
        "example": "const arr = [1,2,3]; arr.reverse(); arr",
        "output": "[3,2,1]",
        "mutates": true
      },
      {
        "name": ".sort(compareFn)",
        "desc": "Mengurutkan array. (Mutasi)",
        "example": "const arr = [3,1,2]; arr.sort((a,b) => a-b); arr",
        "output": "[1,2,3]",
        "mutates": true
      },
      {
        "name": ".fill(value, start?, end?)",
        "desc": "Mengisi elemen dengan nilai statis. (Mutasi)",
        "example": "const arr = [1,2,3]; arr.fill(0, 1, 3); arr",
        "output": "[1,0,0]",
        "mutates": true
      },
      {
        "name": ".copyWithin(target, start, end?)",
        "desc": "Salin bagian array ke posisi lain. (Mutasi)",
        "example": "const arr = [1,2,3,4]; arr.copyWithin(0, 2); arr",
        "output": "[3,4,3,4]",
        "mutates": true
      },
      {
        "name": ".map(cb)",
        "desc": "Transform tiap elemen, return array baru.",
        "example": "[1,2].map(v => v*2)",
        "output": "[2,4]",
        "mutates": false
      },
      {
        "name": ".filter(cb)",
        "desc": "Filter elemen, return array baru.",
        "example": "[1,2,3].filter(v => v>1)",
        "output": "[2,3]",
        "mutates": false
      },
      {
        "name": ".find(cb)",
        "desc": "Cari elemen pertama yang cocok.",
        "example": "[{id:1},{id:2}].find(v => v.id>1)",
        "output": "{id:2}",
        "mutates": false
      },
      {
        "name": ".findIndex(cb)",
        "desc": "Cari index elemen pertama yang cocok.",
        "example": "[{id:1},{id:2}].findIndex(v => v.id>1)",
        "output": "1",
        "mutates": false
      },
      {
        "name": ".findLast(cb)",
        "desc": "Cari elemen terakhir yang cocok.",
        "example": "[1,2,3,2].findLast(v => v===2)",
        "output": "2",
        "mutates": false
      },
      {
        "name": ".findLastIndex(cb)",
        "desc": "Cari index elemen terakhir yang cocok.",
        "example": "[1,2,3,2].findLastIndex(v => v===2)",
        "output": "3",
        "mutates": false
      },
      {
        "name": ".reduce(cb, init?)",
        "desc": "Akumulasi nilai. cb(acc, val, idx, arr).",
        "example": "[1,2,3].reduce((sum, v) => sum+v, 0)",
        "output": "6",
        "mutates": false
      },
      {
        "name": ".reduceRight(cb, init?)",
        "desc": "Akumulasi dari kanan.",
        "example": "[[1,2],[3,4]].reduceRight((flat, arr) => flat.concat(arr), [])",
        "output": "[3,4,1,2]",
        "mutates": false
      },
      {
        "name": ".forEach(cb)",
        "desc": "Menjalankan fungsi untuk setiap elemen. Tidak menghasilkan array baru.",
        "example": "[1,2].forEach(v => console.log(v))",
        "output": "void",
        "mutates": false
      },
      {
        "name": ".some(cb)",
        "desc": "Cek apakah minimal satu elemen cocok.",
        "example": "[1,2,3].some(v => v>2)",
        "output": "true",
        "mutates": false
      },
      {
        "name": ".every(cb)",
        "desc": "Cek apakah semua elemen cocok.",
        "example": "[1,2,3].every(v => v>0)",
        "output": "true",
        "mutates": false
      },
      {
        "name": ".includes(item)",
        "desc": "Mengecek apakah array mengandung elemen tertentu.",
        "example": "[1,2,3].includes(2)",
        "output": "true",
        "mutates": false
      },
      {
        "name": ".indexOf(item)",
        "desc": "Index pertama elemen. -1 jika tidak ditemukan.",
        "example": "[1,2,3].indexOf(2)",
        "output": "1",
        "mutates": false
      },
      {
        "name": ".lastIndexOf(item)",
        "desc": "Index terakhir elemen. -1 jika tidak ditemukan.",
        "example": "[1,2,3,2].lastIndexOf(2)",
        "output": "3",
        "mutates": false
      },
      {
        "name": ".slice(start?, end?)",
        "desc": "Potong array, return array baru.",
        "example": "[1,2,3].slice(0, 2)",
        "output": "[1,2]",
        "mutates": false
      },
      {
        "name": ".concat(arr)",
        "desc": "Menggabungkan array, return array baru.",
        "example": "[1,2].concat([3,4])",
        "output": "[1,2,3,4]",
        "mutates": false
      },
      {
        "name": ".join(separator)",
        "desc": "Menggabungkan array menjadi string.",
        "example": "['a','b'].join('-')",
        "output": "\"a-b\"",
        "mutates": false
      },
      {
        "name": ".flat(depth?)",
        "desc": "Meratakan array bertingkat.",
        "example": "[1,[2,[3]]].flat(2)",
        "output": "[1,2,3]",
        "mutates": false
      },
      {
        "name": ".flatMap(cb)",
        "desc": "Map lalu flat satu tingkat.",
        "example": "[1,2].flatMap(v => [v, v*2])",
        "output": "[1,2,2,4]",
        "mutates": false
      },
      {
        "name": ".entries()",
        "desc": "Iterator pasangan [index, value].",
        "example": "for (const [i,v] of ['a','b'].entries()) console.log(i,v)",
        "output": "0 'a' , 1 'b'",
        "mutates": false
      },
      {
        "name": ".keys()",
        "desc": "Iterator index.",
        "example": "Array.from(['a','b'].keys())",
        "output": "[0,1]",
        "mutates": false
      },
      {
        "name": ".values()",
        "desc": "Iterator nilai.",
        "example": "Array.from(['a','b'].values())",
        "output": "['a','b']",
        "mutates": false
      }
    ]
  },
  "object": [
    {
      "name": "Object.keys(obj)",
      "desc": "Array dari semua key.",
      "example": "Object.keys({a:1,b:2})",
      "output": "[\"a\",\"b\"]"
    },
    {
      "name": "Object.values(obj)",
      "desc": "Array dari semua value.",
      "example": "Object.values({a:1,b:2})",
      "output": "[1, 2]"
    },
    {
      "name": "Object.entries(obj)",
      "desc": "Array pasangan [key, value].",
      "example": "Object.entries({a:1})",
      "output": "[[\"a\", 1]]"
    },
    {
      "name": "Object.assign(target, src)",
      "desc": "Copy properti ke target.",
      "example": "Object.assign({}, {a:1})",
      "output": "{a: 1}"
    },
    {
      "name": "Object.fromEntries(entries)",
      "desc": "Ubah array entries jadi object.",
      "example": "Object.fromEntries([[\"a\", 1]])",
      "output": "{a: 1}"
    },
    {
      "name": "Object.hasOwn(obj, prop)",
      "desc": "Cek properti milik sendiri (modern).",
      "example": "Object.hasOwn({a:1}, 'a')",
      "output": "true"
    },
    {
      "name": "Object.freeze(obj)",
      "desc": "Membekukan object (tidak bisa diubah).",
      "example": "const obj = Object.freeze({a:1}); obj.a = 2; obj.a",
      "output": "1"
    },
    {
      "name": "Object.seal(obj)",
      "desc": "Menyegel object (properti tidak bisa ditambah/hapus).",
      "example": "const obj = Object.seal({a:1}); delete obj.a; obj.a",
      "output": "1"
    },
    {
      "name": "Object.create(proto)",
      "desc": "Membuat object baru dengan prototipe tertentu.",
      "example": "Object.create(null)",
      "output": "{} (tanpa prototype)"
    }
  ],
