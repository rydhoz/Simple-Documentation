  "promise": [
    { "name": "new Promise(executor)", "desc": "Membuat promise.", "example": "new Promise((resolve) => resolve(1))", "output": "Promise{1}" },
    { "name": "Promise.resolve(val)", "desc": "Promise sukses langsung.", "example": "Promise.resolve(42)", "output": "Promise{42}" },
    { "name": "Promise.reject(err)", "desc": "Promise gagal langsung.", "example": "Promise.reject('error')", "output": "Promise{<rejected>}" },
    { "name": ".then(onFulfilled, onRejected?)", "desc": "Menangani hasil sukses.", "example": "Promise.resolve(1).then(v => v+1)", "output": "Promise{2}" },
    { "name": ".catch(onRejected)", "desc": "Menangani error.", "example": "Promise.reject('err').catch(e => e)", "output": "Promise{'err'}" },
    { "name": ".finally(onFinally)", "desc": "Dijalankan apapun hasilnya.", "example": "Promise.resolve().finally(() => console.log('done'))", "output": "void" },
    { "name": "Promise.all([...])", "desc": "Tunggu semua selesai, error jika ada yang gagal.", "example": "Promise.all([Promise.resolve(1), Promise.resolve(2)])", "output": "Promise{[1,2]}" },
    { "name": "Promise.allSettled([...])", "desc": "Tunggu semua selesai (selalu sukses).", "example": "Promise.allSettled([Promise.reject('e')])", "output": "Promise{[{status:'rejected', reason:'e'}]}" },
    { "name": "Promise.race([...])", "desc": "Hasil dari promise pertama yang selesai.", "example": "Promise.race([new Promise(r => setTimeout(r,100,'a')), Promise.resolve('b')])", "output": "Promise{'b'}" },
    { "name": "Promise.any([...])", "desc": "Promise pertama yang sukses, error jika semua gagal.", "example": "Promise.any([Promise.reject('e'), Promise.resolve(2)])", "output": "Promise{2}" }
  ],
