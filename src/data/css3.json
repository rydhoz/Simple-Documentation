{
  "selector": [
    { "name": "*", "desc": "Universal selector — pilih semua elemen.", "example": "* { margin: 0; }", "output": "Semua elemen" },
    { "name": "element", "desc": "Type selector — pilih berdasarkan tag.", "example": "p { color: red; }", "output": "Semua <p>" },
    { "name": ".class", "desc": "Class selector — pilih berdasarkan class.", "example": ".card { padding: 10px; }", "output": "Semua class='card'" },
    { "name": "#id", "desc": "ID selector — pilih berdasarkan id.", "example": "#header { height: 60px; }", "output": "Elemen id='header'" },
    { "name": "[attr]", "desc": "Attribute selector — punya atribut.", "example": "[disabled] { opacity: 0.5; }", "output": "Elemen dengan disabled" },
    { "name": "[attr=value]", "desc": "Attribute selector — nilai tepat.", "example": "[type='text'] { border: 1px solid; }", "output": "input type=text" },
    { "name": "[attr^=value]", "desc": "Attribute selector — diawali value.", "example": "[href^='https'] { color: green; }", "output": "Link HTTPS" },
    { "name": "[attr$=value]", "desc": "Attribute selector — diakhiri value.", "example": "[src$='.png'] { border: none; }", "output": "Gambar PNG" },
    { "name": "[attr*=value]", "desc": "Attribute selector — mengandung value.", "example": "[class*='btn'] { cursor: pointer; }", "output": "Class mengandung btn" },
    { "name": "A B", "desc": "Descendant selector — B di dalam A.", "example": "div p { margin: 0; }", "output": "p di dalam div" },
    { "name": "A > B", "desc": "Child selector — B anak langsung A.", "example": "ul > li { list-style: none; }", "output": "li langsung di ul" },
    { "name": "A + B", "desc": "Adjacent sibling — B tepat setelah A.", "example": "h1 + p { margin-top: 0; }", "output": "p setelah h1" },
    { "name": "A ~ B", "desc": "General sibling — B setelah A.", "example": "h1 ~ p { color: gray; }", "output": "Semua p setelah h1" },
    { "name": "A, B", "desc": "Group selector — A dan B.", "example": "h1, h2, h3 { font-family: sans-serif; }", "output": "h1, h2, h3" },
    { "name": ":first-child", "desc": "Pseudo-class — anak pertama.", "example": "li:first-child { font-weight: bold; }", "output": "li pertama" },
    { "name": ":last-child", "desc": "Pseudo-class — anak terakhir.", "example": "li:last-child { border-bottom: none; }", "output": "li terakhir" },
    { "name": ":nth-child(n)", "desc": "Pseudo-class — anak ke-n.", "example": "tr:nth-child(odd) { background: #eee; }", "output": "Baris ganjil" },
    { "name": ":nth-of-type(n)", "desc": "Pseudo-class — elemen ke-n dari tipenya.", "example": "p:nth-of-type(2) { color: red; }", "output": "p kedua" },
    { "name": ":hover", "desc": "Pseudo-class — saat di-hover.", "example": "a:hover { text-decoration: underline; }", "output": "Saat hover" },
    { "name": ":focus", "desc": "Pseudo-class — saat fokus.", "example": "input:focus { outline: 2px solid blue; }", "output": "Saat fokus" },
    { "name": ":active", "desc": "Pseudo-class — saat diklik.", "example": "button:active { transform: scale(0.98); }", "output": "Saat ditekan" },
    { "name": ":visited", "desc": "Pseudo-class — link sudah dikunjungi.", "example": "a:visited { color: purple; }", "output": "Link visited" },
    { "name": ":disabled", "desc": "Pseudo-class — elemen disabled.", "example": "input:disabled { background: #ccc; }", "output": "Input disabled" },
    { "name": ":checked", "desc": "Pseudo-class — checkbox/radio checked.", "example": "input:checked + label { color: green; }", "output": "Checked" },
    { "name": ":not(selector)", "desc": "Pseudo-class — negasi.", "example": "p:not(.active) { display: none; }", "output": "p tanpa class active" },
    { "name": ":has(selector)", "desc": "Pseudo-class — parent mengandung.", "example": "div:has(img) { padding: 10px; }", "output": "Div yang punya img" },
    { "name": "::before", "desc": "Pseudo-element — sebelum konten.", "example": ".icon::before { content: '★'; }", "output": "★ sebelum teks" },
    { "name": "::after", "desc": "Pseudo-element — setelah konten.", "example": ".clearfix::after { content: ''; display: table; }", "output": "Clearfix" },
    { "name": "::first-letter", "desc": "Pseudo-element — huruf pertama.", "example": "p::first-letter { font-size: 2em; }", "output": "Huruf pertama besar" },
    { "name": "::first-line", "desc": "Pseudo-element — baris pertama.", "example": "p::first-line { font-weight: bold; }", "output": "Baris pertama bold" },
    { "name": "::placeholder", "desc": "Pseudo-element — placeholder input.", "example": "input::placeholder { color: #999; }", "output": "Placeholder abu" },
    { "name": "::selection", "desc": "Pseudo-element — teks yang di-select.", "example": "::selection { background: yellow; }", "output": "Seleksi kuning" }
  ],
