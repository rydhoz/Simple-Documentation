    { "name": "path.extname(p)", "desc": "Ekstensi file.", "example": "path.extname('index.html')", "output": "'.html'" },
    { "name": "path.parse(p)", "desc": "Parse path ke object.", "example": "path.parse('/home/file.txt')", "output": "{ root: '/', dir: '/home', base: 'file.txt', ext: '.txt', name: 'file' }" },
