  "path": [
    { "name": "path.join(...paths)", "desc": "Gabung path secara aman.", "example": "path.join('/home', 'user', 'file.txt')", "output": "/home/user/file.txt" },
    { "name": "path.resolve(...paths)", "desc": "Resolve ke absolute path.", "example": "path.resolve('src', 'app.js')", "output": "/home/user/project/src/app.js" },
    { "name": "path.basename(p)", "desc": "Nama file dari path.", "example": "path.basename('/home/file.txt')", "output": "'file.txt'" },
