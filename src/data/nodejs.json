    { "name": "globalThis", "desc": "Referensi standar ke objek global (Node.js & browser).", "example": "globalThis.setTimeout === setTimeout", "output": "true" },
    { "name": "__dirname", "desc": "Path direktori file saat ini (CommonJS only).", "example": "console.log(__dirname)", "output": "/home/user/project/src" },
    { "name": "__filename", "desc": "Path lengkap file saat ini (CommonJS only).", "example": "console.log(__filename)", "output": "/home/user/project/src/app.js" },
