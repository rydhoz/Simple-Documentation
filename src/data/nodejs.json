    { "name": "\"type\"", "desc": "\"module\" untuk ESM, \"commonjs\" untuk CJS.", "example": "\"type\": \"module\"", "output": "ESM" },
    { "name": "\"scripts\"", "desc": "Custom script (npm run ...).", "example": "\"scripts\": { \"dev\": \"node app.js\" }", "output": "npm run dev" },
    { "name": "\"dependencies\"", "desc": "Package untuk production.", "example": "\"dependencies\": { \"express\": \"^4.18.0\" }", "output": "Production deps" },
    { "name": "\"devDependencies\"", "desc": "Package untuk development.", "example": "\"devDependencies\": { \"typescript\": \"^5.0.0\" }", "output": "Dev deps" },
    { "name": "\"peerDependencies\"", "desc": "Dependency yang harus diinstall user.", "example": "\"peerDependencies\": { \"react\": \"^18.0.0\" }", "output": "Peer deps" },
    { "name": "\"engines\"", "desc": "Versi Node.js minimal.", "example": "\"engines\": { \"node\": \">=18.0.0\" }", "output": "Node >=18" },
    { "name": "\"exports\"", "desc": "Package exports map (modern).", "example": "\"exports\": { \".\": \"./index.js\", \"./utils\": \"./utils.js\" }", "output": "Export map" }
  ]
}