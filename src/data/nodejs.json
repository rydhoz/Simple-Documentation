    { "name": "process.uptime()", "desc": "Uptime proses dalam detik.", "example": "process.uptime()", "output": "123.456" },
    { "name": "process.platform", "desc": "Platform OS (linux, darwin, win32).", "example": "process.platform", "output": "'linux'" },
    { "name": "process.version", "desc": "Versi Node.js.", "example": "process.version", "output": "'v20.10.0'" },
    { "name": "Buffer", "desc": "Menangani data biner.", "example": "Buffer.from('hello')", "output": "<Buffer 68 65 6c 6c 6f>" },
    { "name": "URL", "desc": "Parsing & manipulasi URL (WHATWG API).", "example": "new URL('https://example.com/path?q=1')", "output": "URL object" },
