    { "name": "setInterval(cb, delay)", "desc": "Jalankan callback berulang tiap delay ms.", "example": "setInterval(() => {}, 1000)", "output": "Interval object" },
    { "name": "setImmediate(cb)", "desc": "Jalankan callback di fase check event loop.", "example": "setImmediate(() => console.log('immediate'))", "output": "immediate" },
    { "name": "clearTimeout(id)", "desc": "Hentikan timeout.", "example": "clearTimeout(id)", "output": "Dibatalkan" },
    { "name": "clearInterval(id)", "desc": "Hentikan interval.", "example": "clearInterval(id)", "output": "Dibatalkan" },
    { "name": "clearImmediate(id)", "desc": "Hentikan immediate.", "example": "clearImmediate(id)", "output": "Dibatalkan" }
  ],
