{
  "basic-types": [
    { "name": "string", "desc": "Tipe data teks.", "example": "let name: string = 'Ridho'", "output": "Type: string" },
    { "name": "number", "desc": "Tipe data angka (integer, float, hex, octal, binary).", "example": "let age: number = 25", "output": "Type: number" },
    { "name": "boolean", "desc": "Tipe data true/false.", "example": "let isActive: boolean = true", "output": "Type: boolean" },
    { "name": "null", "desc": "Tipe null (biasanya dengan strictNullChecks).", "example": "let nothing: null = null", "output": "Type: null" },
    { "name": "undefined", "desc": "Tipe undefined.", "example": "let notDefined: undefined = undefined", "output": "Type: undefined" },
    { "name": "any", "desc": "Nonaktifkan type checking (hindari jika bisa).", "example": "let data: any = 123; data = 'hello'", "output": "No error" },
    { "name": "unknown", "desc": "Tipe aman untuk nilai yang tidak diketahui.", "example": "let input: unknown = 'hello'; (input as string).toUpperCase()", "output": "Perlu type assertion" },
    { "name": "void", "desc": "Fungsi tidak mengembalikan nilai.", "example": "function log(msg: string): void { console.log(msg) }", "output": "No return" },
    { "name": "never", "desc": "Fungsi tidak pernah selesai (throw error atau infinite loop).", "example": "function error(msg: string): never { throw new Error(msg) }", "output": "Never" },
    { "name": "array", "desc": "Array dengan tipe elemen tertentu.", "example": "let list: number[] = [1, 2, 3]", "output": "Type: number[]" },
    { "name": "tuple", "desc": "Array dengan jumlah dan tipe elemen tetap.", "example": "let pair: [string, number] = ['age', 25]", "output": "Type: [string, number]" },
    { "name": "enum", "desc": "Enum numerik atau string (gunakan const enum untuk optimasi).", "example": "enum Color { Red, Green, Blue }", "output": "Color.Red = 0" },
    { "name": "literal type", "desc": "Tipe yang hanya menerima nilai literal tertentu.", "example": "let direction: 'left' | 'right' = 'left'", "output": "Union literal" },
    { "name": "union type", "desc": "Gabungan beberapa tipe.", "example": "let id: string | number = 123", "output": "Bisa string atau number" },
    { "name": "intersection type", "desc": "Gabungan semua properti dari beberapa tipe.", "example": "type A = { a: number } & { b: string }", "output": "{ a: number, b: string }" },
    { "name": "object", "desc": "Tipe objek umum.", "example": "let user: object = { name: 'Ridho' }", "output": "Type: object (tidak spesifik)" },
    { "name": "symbol", "desc": "Tipe data simbol (unik).", "example": "let sym: symbol = Symbol('key')", "output": "Type: symbol" },
    { "name": "bigint", "desc": "Tipe bilangan besar.", "example": "let big: bigint = 9007199254740991n", "output": "Type: bigint" },
    { "name": "nullish coalescing", "desc": "Operator ?? untuk memberikan nilai default jika null/undefined.", "example": "let x = foo ?? 'default'", "output": "x = 'default' jika foo null/undefined" },
    { "name": "optional chaining", "desc": "Akses properti dalam dengan aman (?. ).", "example": "let street = user?.address?.street", "output": "undefined jika tidak ada" }
  ],
  "interfaces-types": [
    { "name": "interface", "desc": "Mendefinisikan kontrak objek (bisa di-extend).", "example": "interface User { name: string; age: number }", "output": "User type" },
    { "name": "extending interface", "desc": "Pewarisan interface.", "example": "interface Admin extends User { role: string }", "output": "Admin memiliki name, age, role" },
    { "name": "type alias", "desc": "Alias tipe untuk tipe apa pun.", "example": "type Point = { x: number; y: number }", "output": "Point type" },
    { "name": "type vs interface", "desc": "Interface bisa di-merge deklarasi, type bisa union/intersection.", "example": "type ID = string | number", "output": "Union type" },
    { "name": "readonly", "desc": "Properti tidak bisa diubah setelah inisialisasi.", "example": "interface Config { readonly apiKey: string }", "output": "Tidak bisa reassign" },
    { "name": "optional properties", "desc": "Properti dengan ? tidak wajib.", "example": "interface User { name: string; age?: number }", "output": "age opsional" },
    { "name": "index signatures", "desc": "Properti dengan key dinamis.", "example": "interface Dict { [key: string]: number }", "output": "Semua key string -> number" },
    { "name": "call signature", "desc": "Tipe untuk fungsi.", "example": "interface Fn { (x: number): string }", "output": "Fungsi dengan signature" },
    { "name": "construct signature", "desc": "Tipe untuk constructor.", "example": "interface Ctor { new (x: number): Date }", "output": "Constructor" },
    { "name": "hybrid type", "desc": "Objek yang juga bisa dipanggil.", "example": "interface Counter { (): number; count: number }", "output": "Fungsi + properti" }
  ],
  "generics": [
    { "name": "generic function", "desc": "Fungsi dengan parameter tipe.", "example": "function identity<T>(arg: T): T { return arg }", "output": "identity<string>('hello')" },
    { "name": "generic interface", "desc": "Interface dengan tipe generik.", "example": "interface Box<T> { value: T }", "output": "Box<string>" },
    { "name": "generic constraints", "desc": "Batasi tipe generik dengan extends.", "example": "function getLength<T extends { length: number }>(arg: T): number { return arg.length }", "output": "Terima yang punya .length" },
    { "name": "generic default", "desc": "Nilai default parameter tipe.", "example": "interface Page<T = string> { data: T }", "output": "Default string" },
    { "name": "keyof with generics", "desc": "Ambil key dari tipe.", "example": "function getProperty<T, K extends keyof T>(obj: T, key: K): T[K] { return obj[key] }", "output": "Akses properti aman" },
    { "name": "generic class", "desc": "Kelas dengan tipe generik.", "example": "class Repository<T> { items: T[] = [] }", "output": "Repository<User>" },
    { "name": "infer keyword", "desc": "Ambil tipe dalam conditional type.", "example": "type Return<T> = T extends (...args: any[]) => infer R ? R : never", "output": "ReturnType buatan" },
    { "name": "const type parameters (TS 5.0)", "desc": "Parameter tipe dengan const modifier.", "example": "function getConst<T, const T2>(a: T, b: T2) {}", "output": "Literal type lebih presisi" }
  ],
  "utility-types": [
    { "name": "Partial<T>", "desc": "Semua properti jadi opsional.", "example": "Partial<{ a: number; b: string }>", "output": "{ a?: number; b?: string }" },
    { "name": "Required<T>", "desc": "Semua properti jadi wajib.", "example": "Required<{ a?: number }>", "output": "{ a: number }" },
    { "name": "Readonly<T>", "desc": "Semua properti readonly.", "example": "Readonly<{ a: number }>", "output": "{ readonly a: number }" },
    { "name": "Record<K, T>", "desc": "Objek dengan key K dan value T.", "example": "Record<'a' | 'b', number>", "output": "{ a: number; b: number }" },
    { "name": "Pick<T, K>", "desc": "Ambil subset properti.", "example": "Pick<{ a: number; b: string }, 'a'>", "output": "{ a: number }" },
    { "name": "Omit<T, K>", "desc": "Buang subset properti.", "example": "Omit<{ a: number; b: string }, 'b'>", "output": "{ a: number }" },
    { "name": "Exclude<T, U>", "desc": "Keluarkan tipe yang ada di U dari T.", "example": "Exclude<'a' | 'b' | 'c', 'a'>", "output": "'b' | 'c'" },
    { "name": "Extract<T, U>", "desc": "Ambil tipe yang ada di U dari T.", "example": "Extract<'a' | 'b', 'a' | 'c'>", "output": "'a'" },
    { "name": "NonNullable<T>", "desc": "Buang null dan undefined.", "example": "NonNullable<string | null | undefined>", "output": "string" },
    { "name": "ReturnType<T>", "desc": "Ambil tipe return fungsi.", "example": "ReturnType<() => string>", "output": "string" },
    { "name": "Parameters<T>", "desc": "Ambil tipe parameter fungsi sebagai tuple.", "example": "Parameters<(a: number, b: string) => void>", "output": "[number, string]" },
    { "name": "ConstructorParameters<T>", "desc": "Ambil parameter constructor.", "example": "ConstructorParameters<typeof Date>", "output": "[string | number | Date]" },
    { "name": "InstanceType<T>", "desc": "Ambil tipe instance dari constructor.", "example": "InstanceType<typeof Date>", "output": "Date" },
    { "name": "Awaited<T>", "desc": "Unwrap Promise.", "example": "Awaited<Promise<string>>", "output": "string" },
    { "name": "Uppercase<StringType>", "desc": "Ubah string literal ke uppercase.", "example": "Uppercase<'hello'>", "output": "'HELLO'" },
    { "name": "Lowercase<StringType>", "desc": "Ubah ke lowercase.", "example": "Lowercase<'HELLO'>", "output": "'hello'" },
    { "name": "Capitalize<StringType>", "desc": "Kapitalisasi huruf pertama.", "example": "Capitalize<'hello'>", "output": "'Hello'" },
    { "name": "Uncapitalize<StringType>", "desc": "Uncapitalize huruf pertama.", "example": "Uncapitalize<'Hello'>", "output": "'hello'" }
  ],
  "type-manipulation": [
    { "name": "keyof T", "desc": "Union key dari T.", "example": "type Keys = keyof { a: number; b: string }", "output": "'a' | 'b'" },
    { "name": "typeof", "desc": "Ambil tipe dari nilai/variabel.", "example": "let user = { name: 'Ridho' }; type UserType = typeof user", "output": "{ name: string }" },
    { "name": "T[K] (indexed access)", "desc": "Akses tipe properti.", "example": "type NameType = User['name']", "output": "string" },
    { "name": "conditional types", "desc": "Tipe kondisional T extends U ? X : Y.", "example": "type IsString<T> = T extends string ? true : false", "output": "IsString<'hello'> = true" },
    { "name": "distributive conditional", "desc": "Kondisional terdistribusi pada union.", "example": "type ToArray<T> = T extends any ? T[] : never", "output": "ToArray<string|number> = string[] | number[]" },
    { "name": "mapped types", "desc": "Iterasi key untuk membuat tipe baru.", "example": "type Readonly<T> = { readonly [K in keyof T]: T[K] }", "output": "Custom utility" },
    { "name": "key remapping (as)", "desc": "Ganti key dalam mapped type.", "example": "type Getters<T> = { [K in keyof T as `get${Capitalize<K & string>}`]: () => T[K] }", "output": "Mengubah nama key" },
    { "name": "template literal types", "desc": "Gabung string literal.", "example": "type Greeting = `Hello, ${string}!`", "output": "Semua string dengan prefix 'Hello, ' dan suffix '!'" },
    { "name": "infer in conditional", "desc": "Ekstrak sub-tipe.", "example": "type Unpack<T> = T extends (infer U)[] ? U : T", "output": "Unpack<number[]> = number" },
    { "name": "assertion functions", "desc": "Fungsi yang meyakinkan TS tentang tipe.", "example": "function assert(condition: any, msg?: string): asserts condition", "output": "Type guard" },
    { "name": "const assertions (as const)", "desc": "Buat literal readonly dan narrow.", "example": "let arr = [1, 2, 3] as const", "output": "readonly [1, 2, 3]" },
    { "name": "satisfies operator", "desc": "Validasi tipe tanpa memperluas tipe.", "example": "let x = { a: 1 } satisfies Record<string, number>", "output": "Tetap { a: number }" },
    { "name": "typeof import", "desc": "Ambil tipe dari module yang diimport.", "example": "type MyModule = typeof import('./module')", "output": "Tipe modul" }
  ],
  "narrowing-guards": [
    { "name": "typeof guard", "desc": "Narrowing dengan typeof.", "example": "if (typeof x === 'string') { x.toUpperCase() }", "output": "x jadi string" },
    { "name": "instanceof guard", "desc": "Narrowing dengan instanceof.", "example": "if (x instanceof Date) { x.getFullYear() }", "output": "x jadi Date" },
    { "name": "in operator", "desc": "Cek keberadaan properti.", "example": "if ('name' in obj) { obj.name }", "output": "Tipe narrowed" },
    { "name": "custom type guard", "desc": "Fungsi dengan return type predicate.", "example": "function isString(val: unknown): val is string { return typeof val === 'string' }", "output": "val is string" },
    { "name": "discriminated union", "desc": "Union dengan properti literal pembeda.", "example": "type Shape = { kind: 'circle'; radius: number } | { kind: 'rect'; width: number }", "output": "Switch pada kind" },
    { "name": "exhaustiveness check", "desc": "never untuk memastikan semua kasus ditangani.", "example": "default: const _exhaustive: never = shape", "output": "Error jika ada union baru" },
    { "name": "truthiness narrowing", "desc": "Menggunakan truthy/falsy.", "example": "if (value) { /* value bukan null/undefined */ }", "output": "Narrowing" }
  ],
  "modules-namespaces": [
    { "name": "ESM import/export", "desc": "Sintaks module modern.", "example": "import { fn } from './module'", "output": "ES module" },
    { "name": "default import/export", "desc": "Import/export default.", "example": "import express from 'express'", "output": "Default" },
    { "name": "type import", "desc": "Hanya import tipe (dihapus saat kompilasi).", "example": "import type { User } from './types'", "output": "Type-only import" },
    { "name": "import type dengan inline", "desc": "Import sebagian tipe.", "example": "import { type User, helper } from './module'", "output": "User adalah tipe" },
    { "name": "namespace (ambient/module)", "desc": "Namespace lama, hindari jika bisa.", "example": "namespace MyApp { export interface Config {} }", "output": "Digantikan ES modules" },
    { "name": "declare module", "desc": "Deklarasikan tipe untuk modul eksternal.", "example": "declare module '*.svg' { const content: string; export default content }", "output": "Import SVG" },
    { "name": "global declaration", "desc": "Perluas tipe global (Window, dll).", "example": "declare global { interface Window { myProp: string } }", "output": "Window.myProp" },
    { "name": "moduleResolution", "desc": "Strategi resolusi modul (node16, bundler).", "example": "\"moduleResolution\": \"bundler\"", "output": "tsconfig" }
  ],
  "decorators": [
    { "name": "Class Decorator (Stage 3)", "desc": "Decorator pada class (tidak perlu experimental).", "example": "@sealed class MyClass {}", "output": "Decorator" },
    { "name": "Method Decorator", "desc": "Decorator pada method.", "example": "@log class A { @log greet() {} }", "output": "Logging" },
    { "name": "Accessor Decorator", "desc": "Decorator pada getter/setter.", "example": "@configurable get name() {}", "output": "Accessor" },
    { "name": "Field Decorator", "desc": "Decorator pada field.", "example": "@required name: string", "output": "Field" },
    { "name": "Decorator Context", "desc": "Parameter kedua decorator: ClassMethodDecoratorContext.", "example": "function log(target: any, context: ClassMethodDecoratorContext) {}", "output": "Context metadata" }
  ],
  "enums": [
    { "name": "Numeric enum", "desc": "Enum dengan nilai numerik auto-increment.", "example": "enum Direction { Up, Down }", "output": "Direction.Up = 0" },
    { "name": "String enum", "desc": "Enum dengan nilai string.", "example": "enum Color { Red = 'RED', Green = 'GREEN' }", "output": "Color.Red = 'RED'" },
    { "name": "const enum", "desc": "Enum yang dihapus saat kompilasi, nilai inline.", "example": "const enum Size { Small, Large }", "output": "Tidak ada objek runtime" },
    { "name": "const assertions for enums", "desc": "Alternatif enum pakai as const.", "example": "const Colors = { Red: 'RED', Green: 'GREEN' } as const", "output": "Readonly object" }
  ],
  "tsconfig": [
    { "name": "compilerOptions", "desc": "Opsi utama compiler TS.", "example": "\"compilerOptions\": { \"target\": \"ES2022\" }", "output": "Target ES2022" },
    { "name": "target", "desc": "Versi JavaScript output.", "example": "\"target\": \"ESNext\"", "output": "ES terbaru" },
    { "name": "module", "desc": "Sistem modul (ESNext, Node16, CommonJS).", "example": "\"module\": \"Node16\"", "output": "Node16" },
    { "name": "moduleResolution", "desc": "Cara resolve modul (bundler, node16, classic).", "example": "\"moduleResolution\": \"bundler\"", "output": "Bundler (Next.js)" },
    { "name": "strict", "desc": "Aktifkan semua strict checks.", "example": "\"strict\": true", "output": "Semua ketat" },
    { "name": "strictNullChecks", "desc": "Null dan undefined tidak bisa diberikan ke tipe lain.", "example": "\"strictNullChecks\": true", "output": "null tidak masuk string" },
    { "name": "noUncheckedIndexedAccess", "desc": "Indexed access menghasilkan undefined opsional.", "example": "\"noUncheckedIndexedAccess\": true", "output": "arr[0] mungkin undefined" },
    { "name": "paths", "desc": "Path aliases untuk import.", "example": "\"paths\": { \"@/*\": [\"./src/*\"] }", "output": "import dari @/" },
    { "name": "baseUrl", "desc": "Direktori dasar untuk resolve non-relatif.", "example": "\"baseUrl\": \"./src\"", "output": "Resolve dari src" },
    { "name": "include", "desc": "File yang di-include.", "example": "\"include\": [\"src/**/*\"]", "output": "Include src" },
    { "name": "exclude", "desc": "File yang dikecualikan.", "example": "\"exclude\": [\"node_modules\", \"dist\"]", "output": "Exclude" },
    { "name": "outDir", "desc": "Folder output hasil kompilasi.", "example": "\"outDir\": \"./dist\"", "output": "Output ke dist" },
    { "name": "declaration", "desc": "Generate file .d.ts.", "example": "\"declaration\": true", "output": "File deklarasi" },
    { "name": "declarationMap", "desc": "Generate source map untuk deklarasi.", "example": "\"declarationMap\": true", "output": "Navigasi ke source" },
    { "name": "sourceMap", "desc": "Generate .map untuk debugging.", "example": "\"sourceMap\": true", "output": "Debug di TS" },
    { "name": "lib", "desc": "Library yang disertakan (DOM, ESNext).", "example": "\"lib\": [\"ES2022\", \"DOM\"]", "output": "ES2022 + DOM" },
    { "name": "isolatedModules", "desc": "Pastikan setiap file bisa transpile sendiri (wajib Next.js).", "example": "\"isolatedModules\": true", "output": "Wajib untuk bundler" },
    { "name": "forceConsistentCasingInFileNames", "desc": "Pastikan casing file konsisten.", "example": "\"forceConsistentCasingInFileNames\": true", "output": "Error jika salah casing" },
    { "name": "skipLibCheck", "desc": "Lewati pengecekan tipe di .d.ts.", "example": "\"skipLibCheck\": true", "output": "Cepat" },
    { "name": "noEmit", "desc": "Jangan emit output JS.", "example": "\"noEmit\": true", "output": "Hanya cek tipe" },
    { "name": "esModuleInterop", "desc": "Interoperabilitas CommonJS.", "example": "\"esModuleInterop\": true", "output": "Import default" },
    { "name": "resolveJsonModule", "desc": "Izinkan import JSON.", "example": "\"resolveJsonModule\": true", "output": "Import json" },
    { "name": "allowImportingTsExtensions", "desc": "Izinkan .ts di import path.", "example": "\"allowImportingTsExtensions\": true", "output": "Import './file.ts'" }
  ],
  "react-types": [
    { "name": "React.FC", "desc": "Functional component dengan children opsional.", "example": "const Comp: React.FC<Props> = ({ children }) => <div>{children}</div>", "output": "Component" },
    { "name": "React.ReactNode", "desc": "Semua yang bisa dirender (string, element, array, dll).", "example": "type Props = { children: React.ReactNode }", "output": "Tipe children umum" },
    { "name": "React.ReactElement", "desc": "Hanya JSX element.", "example": "type Props = { element: React.ReactElement }", "output": "JSX element" },
    { "name": "React.CSSProperties", "desc": "Tipe untuk style inline.", "example": "const style: React.CSSProperties = { color: 'red' }", "output": "Style object" },
    { "name": "React.ComponentProps", "desc": "Ambil props dari komponen.", "example": "type BtnProps = React.ComponentProps<'button'>", "output": "Semua atribut button" },
    { "name": "React.HTMLAttributes", "desc": "Atribut HTML generik.", "example": "type DivProps = React.HTMLAttributes<HTMLDivElement>", "output": "Div attributes" },
    { "name": "React.FormEvent", "desc": "Event form.", "example": "onSubmit: (e: React.FormEvent<HTMLFormElement>) => void", "output": "FormEvent" },
    { "name": "React.ChangeEvent", "desc": "Event perubahan input.", "example": "onChange: (e: React.ChangeEvent<HTMLInputElement>) => void", "output": "ChangeEvent" },
    { "name": "React.MouseEvent", "desc": "Event mouse.", "example": "onClick: (e: React.MouseEvent<HTMLButtonElement>) => void", "output": "MouseEvent" },
    { "name": "React.KeyboardEvent", "desc": "Event keyboard.", "example": "onKeyDown: (e: React.KeyboardEvent) => void", "output": "KeyboardEvent" },
    { "name": "React.Ref", "desc": "Ref object atau callback.", "example": "const ref = React.useRef<HTMLDivElement>(null)", "output": "Ref object" },
    { "name": "React.PropsWithChildren", "desc": "Props + children otomatis.", "example": "type Props = React.PropsWithChildren<{ title: string }>", "output": "{ title: string; children?: ReactNode }" },
    { "name": "React.ReactPortal", "desc": "Tipe untuk portal.", "example": "ReactDOM.createPortal(child, container)", "output": "Portal" }
  ],
  "nextjs-types": [
    { "name": "NextPage", "desc": "Tipe untuk halaman Next.js (App Router).", "example": "import { NextPage } from 'next'", "output": "NextPage" },
    { "name": "PageProps (params, searchParams)", "desc": "Props halaman App Router.", "example": "type Props = { params: { id: string }; searchParams: { q: string } }", "output": "Tipe halaman" },
    { "name": "LayoutProps", "desc": "Props layout (children + params).", "example": "type Props = { children: React.ReactNode; params: { slug: string } }", "output": "Layout" },
    { "name": "Metadata", "desc": "Tipe untuk metadata.", "example": "import { Metadata } from 'next'", "output": "Metadata" },
    { "name": "NextApiRequest / NextApiResponse", "desc": "Tipe untuk API Routes (Pages Router).", "example": "import { NextApiRequest, NextApiResponse } from 'next'", "output": "API types" },
    { "name": "RouteHandler (App Router)", "desc": "Tipe untuk route handler.", "example": "import { NextResponse, NextRequest } from 'next/server'", "output": "NextRequest, NextResponse" },
    { "name": "NextAuth types (next-auth)", "desc": "Tipe untuk NextAuth (auth(), session).", "example": "import { getServerSession } from 'next-auth'", "output": "Session" }
  ],
  "error-handling": [
    { "name": "try/catch types", "desc": "Error adalah unknown di catch (useUnknownInCatchVariables).", "example": "catch (e) { if (e instanceof Error) { console.log(e.message) } }", "output": "Error safe" },
    { "name": "asserts condition", "desc": "Fungsi assertion.", "example": "function assert(condition: any, msg: string): asserts condition { if (!condition) throw Error(msg) }", "output": "Narrowing" },
    { "name": "never type", "desc": "Untuk fungsi yang tidak kembali.", "example": "function fail(msg: string): never { throw new Error(msg) }", "output": "Never" },
    { "name": "Promise rejection types", "desc": "Tipe penanganan Promise reject.", "example": "Promise.reject(new Error('fail')) as Promise<never>", "output": "Promise<never>" }
  ],
  "async-await": [
    { "name": "Promise<T>", "desc": "Tipe return async function.", "example": "async function fetchUser(): Promise<User> {}", "output": "Promise" },
    { "name": "Awaited<T>", "desc": "Unwrap tipe Promise.", "example": "type Result = Awaited<Promise<Promise<number>>>", "output": "number" },
    { "name": "async function type", "desc": "Fungsi async otomatis bungkus return dalam Promise.", "example": "const fn = async (): Promise<string> => 'hello'", "output": "Promise<string>" }
  ]
}